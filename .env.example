# Vercel Postgres — copy from your Vercel dashboard
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Google Cloud Discovery Engine
GCP_PROJECT_ID="your-gcp-project-id"
GCP_LOCATION="global"
GCP_ENGINE_ID="your-search-engine-id"
# Path to your service account JSON (local dev only)
GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account-key.json"

# Public base URL of this app (used to generate bookmarklet URLs)
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
